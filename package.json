{
  "author": "Denis <MiskaMyasa> Zaitsev",
  "bugs": {
    "url": "https://github.com/Miskamyasa/eslint-config/issues"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "5.10.0",
    "@eslint/js": "10.0.1",
    "@eslint/markdown": "8.0.2",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-jsonc": "3.2.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-toml": "1.4.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-yml": "3.5.0",
    "jsonc-eslint-parser": "3.1.0",
    "toml-eslint-parser": "1.0.3",
    "typescript-eslint": "8.62.0",
    "yaml-eslint-parser": "2.0.0"
  },
  "description": "Opinionated ESLint config for React + TypeScript projects",
  "devDependencies": {
    "@types/node": "24.12.4",
    "eslint": "10.6.0",
    "jiti": "2.7.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Miskamyasa/eslint-config",
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "react",
    "stylistic"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "name": "@miskamyasa/eslint-config",
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://github.com/Miskamyasa/eslint-config.git"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.1.0"
}
